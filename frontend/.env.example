# Copy this file to .env.local (gitignored) and point it at your running
# FastAPI backend. This is REQUIRED — there is no mock/demo fallback. If
# VITE_API_URL is unset, the app shows a real, visible error state instead
# of a fake answer (see src/api.js: isBackendConfigured()).
#
# Local dev, once uvicorn is running (see backend/README.md):
# VITE_API_URL=http://localhost:8000
#
# Deployed, once the Render service is live:
# VITE_API_URL=https://studymate-backend.onrender.com

VITE_API_URL=
