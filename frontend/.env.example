# Copy this file to .env.local (gitignored) and fill in Vanshi's backend URL
# once it's running. Leave unset to always use the mock data.
#
# Local dev, once she has uvicorn running:
# VITE_API_URL=http://localhost:8000
#
# Deployed, once her Render service is live:
# VITE_API_URL=https://studymate-backend.onrender.com

VITE_API_URL=
