# Copy this file to .env.local (gitignored) and fill in Vanshi's backend URL
# once it's running. Leave unset to always use the mock data.
#
# Local dev, once she has uvicorn running:
# VITE_API_URL=http://localhost:8000
#
# Deployed, once her Render service is live:
# VITE_API_URL=https://studymate-backend.onrender.com
#
# QUICK SANITY TEST (no real backend needed): point this at a dummy,
# unreachable URL, e.g. VITE_API_URL=http://localhost:9999, restart
# `npm run dev`, then:
#   - ask a question -> should still fall back to the mock exchange after
#     ~15s (check the console for a "backend query failed, falling back
#     to mock" warning)
#   - upload a file -> the doc's status dot should turn RED (error), not
#     green -> confirms the real-failure path is now visibly distinct
#     from the "no backend configured" fake-success path
# Remove/empty this line again afterward to go back to normal mock mode.

VITE_API_URL=
